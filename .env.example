# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env, then:
#   export $(grep -v '^#' .env | xargs)
#   python3 seed/generate_data.py
#   python3 pipeline/run_all.py

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Connection string used by all pipeline scripts and the seed generator.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
PG_DSN=postgresql://devops_user:changeme@localhost:5432/devops

# ── Docker Compose (postgres/docker-compose.yml) ──────────────────────────────
# These are read by docker-compose at startup via ${VAR:-default} substitution.
POSTGRES_USER=devops_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=devops

# ── pgAdmin (optional) ────────────────────────────────────────────────────────
# Access pgAdmin at http://localhost:5050 after docker compose up.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
